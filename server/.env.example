# Server Configuration
PORT=5000

# ============================================================
# AI PROVIDER CONFIGURATION
# ============================================================
# Multiple providers are supported. Each provider has its own
# env vars for API keys, base URL, and model. Keys can be
# comma-separated for automatic fallback on quota/rate-limit errors.

# -----------------------------------------------------------
# Provider 1: Stepfun (OpenAI-compatible) — DEFAULT
# -----------------------------------------------------------
# Required: Your Stepfun API key(s) — comma-separated for fallback
OPENAI_API_KEY=sk-your_key1,sk-your_key2

# Optional: API endpoint URL (default: https://api.stepfun.ai/v1)
# Supports any OpenAI-compatible API (OpenAI, Groq, Together.ai, Ollama, etc.)
# For Stepfun: https://api.stepfun.ai/v1
# For OpenAI: https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.stepfun.ai/v1

# Optional: Model to use (default: step-3.7-flash)
# Available: step-3.7-flash, step-3.5-flash, step-1-flash
# OPENAI_MODEL=step-3.7-flash

# -----------------------------------------------------------
# Provider 2: Google Gemini (GenAI) — via OpenAI-compatible endpoint
# -----------------------------------------------------------
# Required: Your Gemini API key(s) — comma-separated for fallback
# GENAI_API_KEY=genapi_1,genapi_2

# OpenAI-compatible endpoint for Gemini
# GENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional: Model to use (default: gemini-2.0-flash)
# Available: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
# GENAI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------
# Provider 3: Ollama (Local) — OpenAI-compatible, runs locally
# -----------------------------------------------------------
# Ollama runs entirely on your machine. No API key is required.
# Download from: https://ollama.com
#
# Pull a model first:
#   ollama pull llama3.1
#
# Start the Ollama server (it runs on port 11434 by default):
#   ollama serve

# Not required for local Ollama (leave empty):
# OLLAMA_API_KEY=

# Optional: API endpoint (default: http://localhost:11434/v1)
# Only change this if you run Ollama on a different host/port:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Optional: Model to use (default: llama3.1)
# Available models depend on what you've pulled:
#   ollama list
# Common options: llama3.1, llama3, mistral, codellama, deepseek-coder, mixtral, phi3, gemma2, qwen2
# OLLAMA_MODEL=llama3.1
