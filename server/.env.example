# Server Configuration
PORT=5000

# OpenAI API Configuration
# Required: Your API key for the AI migration engine
OPENAI_API_KEY=your_api_key_here

# Optional: API endpoint URL (default: https://zenmux.ai/api/v1)
# Supports any OpenAI-compatible API (OpenAI, Groq, Together.ai, Ollama, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use for migration (default: stepfun/step-3.7-flash-free)
# For OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# For free alternatives: stepfun/step-3.7-flash-free, llama-3-70b-8192
# OPENAI_MODEL=gpt-4
