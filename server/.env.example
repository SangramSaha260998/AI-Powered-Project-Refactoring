# Server Configuration
PORT=5000

# ============================================================
# AI PROVIDER CONFIGURATION
# ============================================================
# Multiple providers are supported. Each provider has its own
# env vars for API keys, base URL, and model. Keys can be
# comma-separated for automatic fallback on quota/rate-limit errors.
#
# Cross-provider fallback is ALWAYS on: if the selected provider's
# keys are exhausted (401/402/403/429/5xx/network), the next configured
# provider in the chain is tried with its own key + default model.
# AI_FALLBACK_CHAIN=genai,openrouter,ollama
#
# Ollama Cloud is auto-included when OLLAMA_API_KEY is set.
# Local Ollama requires: OLLAMA_ENABLED=true and OLLAMA_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------
# Provider 1: OpenRouter — free model catalog (DEFAULT)
# -----------------------------------------------------------
# Required: Your OpenRouter API key(s) — comma-separated for fallback
OPENROUTER_API_KEY=sk-or-your_key

# Optional: API endpoint URL (default: https://openrouter.ai/api/v1)
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional: Default model (UI selection overrides this)
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# -----------------------------------------------------------
# Provider 2: Google Gemini (GenAI) — via OpenAI-compatible endpoint
# -----------------------------------------------------------
# Required: Your Gemini API key(s) — comma-separated for fallback
# GENAI_API_KEY=genapi_1,genapi_2

# OpenAI-compatible endpoint for Gemini
# GENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Optional: Model to use (default: gemini-2.0-flash)
# Available: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
# GENAI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------
# Provider 3: Ollama Cloud — OpenAI-compatible hosted API
# -----------------------------------------------------------
# Create a key at: https://ollama.com/settings/keys
OLLAMA_API_KEY=your_ollama_cloud_key

# Cloud endpoint (default). For local Ollama instead:
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_ENABLED=true
OLLAMA_BASE_URL=https://ollama.com/v1

# Default cloud model (UI selection overrides this)
# Popular: gpt-oss:20b, gpt-oss:120b, qwen3-coder:480b, deepseek-v3.1:671b
OLLAMA_MODEL=gpt-oss:20b
